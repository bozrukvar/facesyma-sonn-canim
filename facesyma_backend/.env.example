# facesyma_backend/.env.example
# Copy to .env and fill in real values. Never commit .env to git.

# Django
DJANGO_SETTINGS_MODULE=facesyma_project.settings
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=api.facesyma.com,localhost,127.0.0.1,backend,nginx

# MongoDB Atlas (or self-hosted)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/facesyma-backend?retryWrites=true&w=majority

# JWT
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_EXP_HOURS=1
JWT_REFRESH_EXP_DAYS=30

# Admin Panel JWT (separate from user JWT)
ADMIN_JWT_SECRET=change-me-to-a-different-random-secret
ADMIN_JWT_EXP_HOURS=8

# Google OAuth (Google Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com

# Payment Processing — Google Pay & Apple Pay (client-side, no secret key needed)
GOOGLE_PAY_MERCHANT_ID=your_google_pay_merchant_id
APPLE_PAY_MERCHANT_ID=your_apple_pay_merchant_id
# Vakıfbank Sanal Pos — ileriki versiyon ile entegre edilecek:
# VAKIFBANK_VPP_MERCHANT_ID=
# VAKIFBANK_VPP_TERMINAL_ID=
# VAKIFBANK_VPP_PASSWORD=
# VAKIFBANK_VPP_BASE_URL=

# Email (SMTP) — for password reset and alert emails
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@facesyma.com
EMAIL_HOST_PASSWORD=your-app-password

# Slack — incoming webhook for alert notifications
# Create at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Face Analysis Engine
FACESYMA_ENGINE_PATH=/app/facesyma_revize

# Redis (Docker Compose service name or host)
REDIS_HOST=redis
REDIS_PORT=6379

# Security (production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000

# Server
HOST=0.0.0.0
PORT=8000
