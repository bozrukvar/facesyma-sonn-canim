# Django Configuration for Docker
DJANGO_SETTINGS_MODULE=facesyma_project.settings
DJANGO_SECRET_KEY=facesyma-production-secret-key-change-in-prod
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx

# MongoDB Atlas
MONGO_URI=mongodb+srv://facesyma:FaceSyma2021@cluster0.io98c.mongodb.net/myFirstDatabase?ssl=true&ssl_cert_reqs=CERT_NONE

# JWT Configuration
JWT_SECRET=facesyma-jwt-secret-key
JWT_ACCESS_EXP_HOURS=24
JWT_REFRESH_EXP_DAYS=30

# Google OAuth (Optional - for mobile app)
# TODO: Replace with your actual Google Client ID from https://console.cloud.google.com
GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com

# Payment Processing
# Stripe (International)
STRIPE_API_KEY=sk_test_51234567890
STRIPE_WEBHOOK_SECRET=whsec_test_1234567890
STRIPE_PUBLISHABLE_KEY=pk_test_1234567890

# iyzico (Turkey)
IYZICO_API_KEY=sandbox-key-xxx
IYZICO_SECRET_KEY=sandbox-secret-xxx

# Face Analysis Engine Path
FACESYMA_ENGINE_PATH=/app/facesyma_revize

# Server
HOST=0.0.0.0
PORT=8000
