# ============================================
# FACESYMA ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to each service directory and 
# update with your actual values

# ============================================
# BACKEND (.env for facesyma_backend/)
# ============================================
DJANGO_SETTINGS_MODULE=facesyma_project.settings
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend,nginx,your-domain.com

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?ssl=true&ssl_cert_reqs=CERT_NONE

# JWT Configuration
JWT_SECRET=your-jwt-secret-key
JWT_ACCESS_EXP_HOURS=24
JWT_REFRESH_EXP_DAYS=30

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Slack Webhook for Alert Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Face Analysis Engine
FACESYMA_ENGINE_PATH=/app/facesyma_revize

# Server
HOST=0.0.0.0
PORT=8000

# ============================================
# AI CHAT SERVICE (.env for facesyma_ai/)
# ============================================
OLLAMA_URL=http://ollama:11434
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?ssl=true
JWT_SECRET=your-jwt-secret-key

# ============================================
# COACH API (.env for facesyma_coach/)
# ============================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?ssl=true
JWT_SECRET=your-jwt-secret-key
HOST=0.0.0.0
PORT=8003

# ============================================
# TEST MODULE (.env for facesyma_test/)
# ============================================
OLLAMA_URL=http://ollama:11434
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database?ssl=true
JWT_SECRET=your-jwt-secret-key

# ============================================
# DOCKER COMPOSE ENVIRONMENT
# ============================================
# For docker-compose.yml global settings
COMPOSE_PROJECT_NAME=facesyma
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
