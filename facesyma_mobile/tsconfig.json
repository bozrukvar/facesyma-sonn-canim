{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@screens/*":    ["src/screens/*"],
      "@components/*": ["src/components/*"],
      "@services/*":   ["src/services/*"],
      "@store/*":      ["src/store/*"],
      "@utils/*":      ["src/utils/*"]
    }
  }
}
