{
  "extends": "@react-native/typescript-config/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "types": [],
    "baseUrl": ".",
    "paths": {
      "react-native":  ["node_modules/react-native/types/index.d.ts"],
      "@screens/*":    ["src/screens/*"],
      "@components/*": ["src/components/*"],
      "@services/*":   ["src/services/*"],
      "@store/*":      ["src/store/*"],
      "@utils/*":      ["src/utils/*"]
    }
  },
  "include": ["src/**/*", "App.tsx", "index.js"]
}
