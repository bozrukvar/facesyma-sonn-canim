# vLLM model sunucusu URL'i
VLLM_URL=http://localhost:8001

# Fine-tuned model ID (vLLM --model parametresiyle eşleşmeli)
MODEL_ID=facesyma-llama3.1-8b

# MongoDB bağlantısı
MONGO_URI=mongodb+srv://facesyma:SIFRE@cluster0.io98c.mongodb.net/myFirstDatabase?ssl=true&ssl_cert_reqs=CERT_NONE

# JWT
JWT_SECRET=facesyma-jwt-secret-change-in-production

# Sistem promptu için facesyma_ai klasör yolu
FACESYMA_AI_PATH=/app/facesyma_ai

# Model parametreleri
MAX_TOKENS=1024
TEMPERATURE=0.7

# HuggingFace (model push için)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
